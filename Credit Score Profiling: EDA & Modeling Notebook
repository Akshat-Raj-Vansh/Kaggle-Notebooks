"source":"# Map target variable mapping beforehand to avoid issues\ntarget_map = {'Poor': 1, 'Standard': 0, 'Good': 0}\ndf['Credit_Score'] = df['Credit_Score'].map(target_map)\n\n# Split the dataset into train and validation sets first to prevent data leakage during scaling/imputation/encoding\ndf_train, df_val = train_test_split(df, test_size=0.2, random_state=42, stratify=df['Credit_Score'])\n\n# Identify numeric vs categorical columns robustly\ncat_cols = [col for col in df.columns if not pd.api.types.is_numeric_dtype(df[col]) and col != 'Credit_Score']\nnum_cols = [col for col in df.columns if pd.api.types.is_numeric_dtype(df[col]) and col != 'Credit_Score' and col not in mlb.classes_]\n\n# Numerical Imputer (fit on train only)\nnum_imputer = SimpleImputer(strategy='median')\ndf_train[num_cols] = num_imputer.fit_transform(df_train[num_cols])\ndf_val[num_cols] = num_imputer.transform(df_val[num_cols])\noot_df[num_cols] = num_imputer.transform(oot_df[num_cols])\n\n# Categorical Imputer (fit on train only)\nif len(cat_cols) > 0:\n    cat_imputer = SimpleImputer(strategy='most_frequent')\n    df_train[cat_cols] = cat_imputer.fit_transform(df_train[cat_cols])\n    df_val[cat_cols] = cat_imputer.transform(df_val[cat_cols])\n    oot_df[cat_cols] = cat_imputer.transform(oot_df[cat_cols])\n\nprint(f\"Numerical columns imputed: {num_cols}\\n\")\nprint(f\"Categorical columns imputed: {cat_cols}\")\nprint(f\"Missing values remaining in Train: {df_train[num_cols + cat_cols].isnull().sum().sum()}\")\nprint(f\"Missing values remaining in Val: {df_val[num_cols + cat_cols].isnull().sum().sum()}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-10T15:59:18.085303Z","iopub.execute_input":"2026-06-10T15:59:18.085579Z","iopub.status.idle":"2026-06-10T15:59:18.522611Z","shell.execute_reply.started":"2026-06-10T15:59:18.085553Z","shell.execute_reply":"2026-06-10T15:59:18.521794Z"}},"outputs":[{"name":"stdout","text":"Numerical columns imputed: ['Age', 'Annual_Income', 'Monthly_Inhand_Salary', 'Num_Bank_Accounts', 'Num_Credit_Card', 'Interest_Rate', 'Num_of_Loan', 'Delay_from_due_date', 'Num_of_Delayed_Payment', 'Changed_Credit_Limit', 'Num_Credit_Inquiries', 'Outstanding_Debt', 'Credit_Utilization_Ratio', 'Total_EMI_per_month', 'Amount_invested_monthly', 'Monthly_Balance', 'Credit_History_Age_Total']\n\nCategorical columns imputed: ['Month', 'Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour']\nMissing values remaining in Train: 0\nMissing values remaining in Val: 0\n","output_type":"stream"}],"execution_count":886},{"cell_type":"markdown","source":"## 📏 Encoding and Feature Scaling\n\nWe one-hot encode all categorical columns, align features between training, validation and test sets (avoiding dummy category leakage), and scale numerical variables using `StandardScaler` (fitting the scaler ONLY on the train split).","metadata":{}},{"cell_type":"code","source":"# One-hot encode features separately on splits and reindex to align columns (preventing category mismatch leakage)\nencode_cols = ['Month', 'Occupation', 'Credit_Mix', 'Payment_of_Min_Amount', 'Payment_Behaviour']\ndf_train_encoded = pd.get_dummies(df_train, columns=encode_cols, drop_first=True)\ndf_val_encoded = pd.get_dummies(df_val, columns=encode_cols, drop_first=True)\noot_df_encoded = pd.get_dummies(oot_df, columns=encode_cols, drop_first=True)\n\n# Separate inputs and targets\nX_train = df_train_encoded.drop(columns=['Credit_Score'])\ny_train = df_train_encoded['Credit_Score']\n\nX_val = df_val_encoded.drop(columns=['Credit_Score'])\ny_val = df_val_encoded['Credit_Score']\n\n# Align splits\nX_val = X_val.reindex(columns=X_train.columns, fill_value=0)\nX_test = oot_df_encoded.reindex(columns=X_train.columns, fill_value=0)\n\n# Scale features (StandardScaler fit on train split only)\nscaler = StandardScaler()\nX_train_scaled = pd.DataFrame(scaler.fit_transform(X_train), columns=X_train.columns, index=X_train.index)\nX_val_scaled = pd.DataFr