"code","source":"for data in [df, oot_df]:\n    data['Type_of_Loan'] = data['Type_of_Loan'].fillna('Unknown Loan')\n    # Replace 'and' with comma to split cleanly\n    cleaned = data['Type_of_Loan'].astype(str).str.replace(r'\\band\\b', ',', regex=True)\n    data['Type_of_Loan_Clean'] = cleaned.str.split(r',\\s*')\n    data['Type_of_Loan_Clean'] = data['Type_of_Loan_Clean'].apply(\n        lambda d: [x.strip() for x in d if x.strip()] if isinstance(d, list) else ['Unknown Loan']\n    )\n\n# Fit MultiLabelBinarizer on training set\nmlb = MultiLabelBinarizer()\ntrain_loan_encoded = pd.DataFrame(\n    mlb.fit_transform(df['Type_of_Loan_Clean']), \n    columns=mlb.classes_, \n    index=df.index\n)\ntest_loan_encoded = pd.DataFrame(\n    mlb.transform(oot_df['Type_of_Loan_Clean']), \n    columns=mlb.classes_, \n    index=oot_df.index\n)\n\n# Concat columns and drop raw inputs\ndf = pd.concat([df, train_loan_encoded], axis=1)\noot_df = pd.concat([oot_df, test_loan_encoded], axis=1)\n\ncolumns_to_drop = ['Type_of_Loan', 'Type_of_Loan_Clean']\ndf.drop(columns=columns_to_drop, inplace=True, errors='ignore')\noot_df.drop(columns=columns_to_drop, inplace=True, errors='ignore')\n\nprint(f\"Type_of_Loan binarized. Added {len(mlb.classes_)} new binary columns:\", list(mlb.classes_))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-10T15:59:16.540265Z","iopub.execute_input":"2026-06-10T15:59:16.540609Z","iopub.status.idle":"2026-06-10T15:59:17.939501Z","shell.execute_reply.started":"2026-06-10T15:59:16.540573Z","shell.execute_reply":"2026-06-10T15:59:17.938641Z"}},"outputs":[{"name":"stdout","text":"Type_of_Loan binarized. Added 10 new binary columns: ['Auto Loan', 'Credit-Builder Loan', 'Debt Consolidation Loan', 'Home Equity Loan', 'Mortgage Loan', 'Not Specified', 'Payday Loan', 'Personal Loan', 'Student Loan', 'Unknown Loan']\n","output_type":"stream"}],"execution_count":881},{"cell_type":"markdown","source":"### 16. Cleaning `Credit_Mix`\nWe replace plac