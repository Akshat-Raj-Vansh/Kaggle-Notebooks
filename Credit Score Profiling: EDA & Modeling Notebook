oring='roc_auc', n_jobs=-1)\n    return scores.mean()\n\n# ─────────────────────────────────────────────\n# OPTUNA STUDY\n# ─────────────────────────────────────────────\nif OPTUNA_AVAILABLE and XGBOOST_AVAILABLE:\n    study = optuna.create_study(\n        direction='maximize',\n        sampler=optuna.samplers.TPESampler(seed=42),\n        pruner=optuna.pruners.MedianPruner(n_startup_trials=10, n_warmup_steps=5)\n    )\n    study.optimize(objective, n_trials=20, show_progress_bar=True)\n    print(f\"\\nBest CV AUC:  {study.best_value:.4f}\")\n    print(f\"Best Params:  {study.best_params}\")\n    \n    # FINAL MODEL — fit on train, evaluate on test\n    best_params = study.best_params\n    best_params.update({\n        'objective': 'binary:logistic',\n        'eval_metric': 'auc',\n        'verbosity': 0,\n        'random_state': 42,\n        'n_jobs': -1\n    })\n    final_model = XGBClassifier(**best_params)\n    final_model.fit(X_train, y_train)\nelse:\n    print(\"XGBoost or Optuna not available. Using best baseline model (Random Forest) as final_model.\")\n    final_model = trained_models.get('Random Forest')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-10T15:59:53.426994Z","iopub.execute_input":"2026-06-10T15:59:53.427336Z","iopub.status.idle":"2026-06-10T16:06:17.064361Z","shell.execute_reply.started":"2026-06-10T15:59:53.427299Z","shell.execute_reply":"2026-06-10T16:06:17.063449Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"  0%|          | 0/20 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"6625d5d6254e4bd98c44338e706c5927"}},"metadata":{}},{"name":"stdout","text":"\nBest CV AUC:  0.9325\nBest Params:  {'n_estimators': 600, 'max_depth': 8, 'learning_rate': 0.15499900604026037, 'subsample': 0.7909489813612176, 'colsample_bytree': 0.9257114721202204, 'min_child_weight': 6, 'gamma': 0.42605392158553135, 'reg_alpha': 0.004124505262533787, 'reg_lambda': 0