tatus.busy":"2026-06-14T18:37:12.933063Z","iopub.execute_input":"2026-06-14T18:37:12.933361Z","iopub.status.idle":"2026-06-14T18:37:12.948589Z","shell.execute_reply.started":"2026-06-14T18:37:12.933322Z","shell.execute_reply":"2026-06-14T18:37:12.947657Z"}},"outputs":[{"execution_count":71,"output_type":"execute_result","data":{"text/plain":"21"},"metadata":{}}],"execution_count":71},{"cell_type":"code","source":"# Display the column names of all features in the dataset\ndf.columns","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:12.949823Z","iopub.execute_input":"2026-06-14T18:37:12.950288Z","iopub.status.idle":"2026-06-14T18:37:12.968638Z","shell.execute_reply.started":"2026-06-14T18:37:12.950247Z","shell.execute_reply":"2026-06-14T18:37:12.967851Z"}},"outputs":[{"execution_count":72,"output_type":"execute_result","data":{"text/plain":"Index(['battery_power', 'blue', 'clock_speed', 'dual_sim', 'fc', 'four_g',\n       'int_memory', 'm_dep', 'mobile_wt', 'n_cores', 'pc', 'px_height',\n       'px_width', 'ram', 'sc_h', 'sc_w', 'talk_time', 'three_g',\n       'touch_screen', 'wifi', 'price_range'],\n      dtype='object')"},"metadata":{}}],"execution_count":72},{"cell_type":"markdown","source":"## 5. Feature Categorization & Preprocessing\nWe map raw feature names to human-readable labels for clean visualization. We then categorize features programmatically into **Continuous** and **Categorical / Ordinal** lists based on their cardinality.","metadata":{}},{"cell_type":"code","source":"# Map technical abbreviations to user-friendly column descriptions\nfeature_mapping = {\n    'battery_power': 'Battery Capacity (mAh)',\n    'blue': 'Bluetooth',\n    'clock_speed': 'Processor Clock Speed (GHz)',\n    'dual_sim': 'Dual SIM Support',\n    'fc': 'Front Camera (MP)',\n    'four_g': '4G Support',\n    'int_memory': 'Internal Memory (GB)',\n    'm_dep': 'Mobile Depth (cm)',\n    'mobile_wt': 'Mobile Weight (g)',\n    'n_cores': 'Number of Processor Cores',\n    'pc': 'Primary Camera (MP)',\n    'px_height': 'Pixel Height',\n    'px_width': 'Pixel Width',\n    'ram': 'RAM (MB)',\n    'sc_h': 'Screen Height (cm)',\n    'sc_w': 'Screen Width (cm)',\n    'talk_time': 'Talk Time (hours)',\n    'three_g': '3G Support',\n    'touch_screen': 'Touch Screen',\n    'wifi': 'Wi-Fi',\n    'price_range': 'Price Range'\n}","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:12.969905Z","iopub.execute_input":"2026-06-14T18:37:12.970315Z","iopub.status.idle":"2026-06-14T18:37:12.987214Z","shell.execute_reply.started":"2026-06-14T18:37:12.970276Z","shell.execute_reply":"2026-06-14T18:37:12.986102Z"}},"outputs":[],"execution_count":73},{"cell_type":"code","source":"# Segregate continuous from ordinal/categorical features based on cardinality (>10 unique values)\ncontinuous_features = []\nordinal_features = []\ntarget = 'price_range'\n\nfor col in df.columns:\n    if col == target:\n        continue\n    if df[col].nunique() > 10 or df[col].dtype == 'float':\n        continuous_features.append(col)\n    else:\n        ordinal_features.append(col)\n\nprint('Continuous Features: ', continuous_features)\nprint('Ordinal Features:', ordinal_features)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:12.99059Z","iopub.execute_input":"2026-06-14T18:37:12.991036Z","iopub.status.idle":"2026-06-14T18:37:13.013428Z","shell.execute_reply.started":"2026-06-14T18:37:12.990998Z","shell.execute_reply":"2026-06-14T18:37:13.01236Z"}},"outputs":[{"name":"stdout","text":"Continuous Features:  ['battery_power', 'clock_speed', 'fc', 'int_memory', 'm_dep', 'mobile_wt', 'pc', 'px_height', 'px_width', 'ram', 'sc_h', 'sc_w', 'talk_time']\nOrdinal Features: ['blue', 'dual_sim', 'four_g', 'n_cores', 'three_g', 'touch_screen', 'wifi']\n","output_type":"stream"}],"execution_count":74},{"cell_type":"code","source":"# Display counts of continuous vs. ordinal features\nprint(f'Count of Continuous Features: {len(continuous_features)}')\nprint(f'Count of Ordinal Features: {len(ordinal_features)}')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:13.014637Z","iopub.execute_input":"2026-06-14T18:37:13.014948Z","iopub.status.idle":"2026-06-14T18:37:13.028862Z","shell.execute_reply.started":"2026-06-14T18:37:13.014919Z","shell.execute_reply":"2026-06-14T18:37:13.027737Z"}},"outputs":[{"name":"stdout","text":"Count of Continuous Features: 13\nCount of Ordinal Features: 7\n","output_type":"stream"}],"execution_count":75},{"cell_type":"markdown","source":"## 6. Visual EDA: Continuous Features vs. Price Range\nTo visualize how continuous variables correlate with target price ranges, we define a custom color palette representing the four tiers and plot seaborn violin plots.","metadata":{}},{"cell_type":"code","source":"# Define a custom color palette for the 4 price ranges using cubehelix palette\n# 'rot' controls how much it rotates through other colors\ncustom_cube = sns.cubehelix_palette(n_colors=4, start=3.2, rot=-0.4, dark=0.3, light=0.9)\n\nsns.palplot(custom_cube)\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:13.029945Z","iopub.execute_input":"2026-06-14T18:37:13.030243Z","iopub.status.idle":"2026-06-14T18:37:13.085858Z","shell.execute_reply.started":"2026-06-14T18:37:13.030215Z","shell.execute_reply":"2026-06-14T18:37:13.085033Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 400x100 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":76},{"cell_type":"code","source":"# Plot violin plots for all continuous features across the price ranges\nfig, axes = plt.subplots(12, 3, figsize=(16, 52))\naxes = axes.flatten()\n\nfor idx, col in enumerate(continuous_features):\n    ax = axes[idx]\n    sns.violinplot(data=df, x=target, y=col, ax=ax, palette=custom_cube)\n    ax.set_title(f'Distribution of {feature_mapping[col]} vs Price Range', fontsize=12, fontweight='bold')\n    ax.set_xlabel(f'{feature_mapping[target]}')\n    ax.set_ylabel(f'{feature_mapping[col]}')\n    \nfor i in range(len(continuous_features), len(axes)):\n    fig.delaxes(axes[i])\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:13.086898Z","iopub.execute_input":"2026-06-14T18:37:13.087491Z","iopub.status.idle":"2026-06-14T18:37:16.365471Z","shell.execute_reply.started":"2026-06-14T18:37:13.087461Z","shell.execute_reply":"2026-06-14T18:37:16.364628Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x5200 with 13 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":77},{"cell_type":"markdown","source":"## 7. Exploratory Data Analysis Observations: Continuous Features vs. Price Range\n\nA structured breakdown of insights gathered from violin plots, evaluating how each continuous feature's behavior changes across mobile device Price Range tiers:\n\n| Tier | Label |\n|------|-------|\n| 0 | Low Cost |\n| 1 | Medium Cost |\n| 2 | High Cost |\n| 3 | Very High Cost |\n\n---\n\n### 1. Strong Predictors (High Visual Variance Across Tiers)\n\nThese features show a distinct, progressive shift in their distributions as price increases, making them excellent candidates for machine learning classification.\n\n#### RAM (MB)\n\n- **Observation:** This feature demonstrates an absolute, non-overlapping upward leap in both medians and interquartile ranges (IQRs) with every single price step.\n- **Insight:** Tier 0 is strictly capped under 2000 MB, while Tier 3 is almost exclusively populated by devices pushing 3000 to 4000+ MB. This distinct separation makes it the **single most powerful feature** in the dataset for price classification.\n\n#### Battery Capacity (mAh)\n\n- **Observation:** The median battery capacity steadily climbs with each consecutive price tier.\n- **Insight:** While a baseline capacity around 500–1000 mAh exists in all tiers, the upper quartiles and overall density shift heavily upward in Tier 3. High-tier devices strongly favor larger battery capacities to support premium hardware features.\n\n#### Pixel Width & Pixel Height\n\n- **Observation:** Both display a highly synchronized, progressive upward shift in density across the price tiers.\n- **Insight:** As price increases, the concentration of low-resolution screens falls away, and the distribution expands significantly into the upper pixel thresholds. Premium tiers place a heavy baseline emphasis on high-resolution panels.\n\n#### Internal Memory (GB)\n\n- **Observation:** There is a pronounced, step-by-step upward migration of the inner quartiles (the black core box) from Tier 0 to Tier 3.\n- **Insight:** In Tier 0, the data density is concentrated heavily at lower storage values. By Tier 3, the distribution flips — showing a massive concentration of devices maximized at top-tier internal storage levels. This is one of the cleanest linear relationships in the dataset.\n\n---\n\n### 2. Moderate / Mixed Predictors\n\nThese features offer some distributional variance but contain significant overlap across categories.\n\n#### Processor Clock Speed (GHz)\n\n- **Observation:** The overall shape of the violins remains relatively uniform, but the internal median marker shows a subtle, gradual increase.\n- **Insight:** Lower-priced tiers have a slightly higher density of lower clock speeds (0.5 GHz range). However, high clock speed processors can still be found across all price points — indicating it acts as a **supplementary differentiator** rather than a standalone price determinant.\n\n#### Screen Height (cm) & Screen Width (cm)\n\n- **Observation:** The distribution shapes stay heavily identical across the board, though the upper quartiles expand slightly broader at the top end for high-tier phones.\n- **Insight:** Brand tiers do not strictly gate the physical dimensions of the chassis or glass. While premium devices slightly lean toward larger form factors, there is too much overlap to use these as primary tier determinants.\n\n---\n\n### 3. Weak / Non-Predictive Features (Identical Distributions)\n\nThese features show completely static shapes, distributions, and medians across all four price points, indicating negligible predictive power for the target variable.\n\n#### Mobile Weight (g) & Mobile Depth (cm)\n\n- **Observation:** The violins are practically carbon copies across Tiers 0, 1, 2, and 3. The interquartile ranges, medians, and overall spread do not deviate.\n- **Insight:** Physical dimensions and weight form a completely balanced distribution across the entire dataset, implying that build thickness or weight does **not** correlate with market positioning or pricing tiers.\n\n#### Talk Time (hours)\n\n- **Observation:** The distribution shape, range, and central median remain virtually unchanged from low cost to very high cost tiers.\n- **Insight:** The maximum duration of continuous call time supported by the hardware configuration shows zero variance across price brackets, providing no discriminatory value.\n\n#### Front Camera & Primary Camera (MP)\n\n- **Observation:** Surprisingly, the megapixel distributions for both the front and primary cameras look almost identical across all four price groups.\n- **Insight:** The median megapixel counts stay entirely flat. High-megapixel and low-megapixel variations exist in roughly equal measure across budget and premium devices alike — suggesting megapixel count alone is a **marketing metric** rather than a true premium price barrier in this dataset.\n\n---\n\n### Summary Matrix for Feature Selection\n\n| Feature | Trend Profile | Data Spread Behavior | Modeling Utility |\n|---|---|---|---|\n| RAM | Absolute Separation | Non-overlapping vertical leaps per tier | 🌟 Top Feature |\n| Internal Memory | Direct Linear Growth | Density shifts to maximum values at Tier 3 | ✅ Critical Feature |\n| Battery Capacity | Progressive Increase | Higher medians and tighter top-end clusters | ✅ High Utility |\n| Pixel Width & Height | Simultaneous Growth | Density clears out from lower boundaries | ✅ High Utility |\n| Clock Speed | Marginal Upward Shift | Substantial overlap across all categories | ⚠️ Low / Moderate Utility |\n| Screen Height & Width | Mostly Static | Slight broadening at the top end | ⚠️ Low / Moderate Utility |\n| Primary / Front Camera | Flat / Unchanged | Uniform variance across all tiers | ❌ Negligible Utility |\n| Talk Time | Flat / Unchanged | Completely identical distributions | ❌ Negligible Utility |\n| Weight / Depth | Flat / Unchanged | Identical shapes and central tendencies | ❌ Drop Candidate |","metadata":{}},{"cell_type":"markdown","source":"## 8. Visual EDA: Categorical & Ordinal Features vs. Price Range\nWe analyze binary and low-cardinality ordinal features (like Bluetooth, 4G, Cores) using contingency table heatmaps. This will reveal if certain tiers have higher proportions of high-value features.","metadata":{}},{"cell_type":"code","source":"# Generate subplots showing cross-tabulations of ordinal features vs price range\nfig, axes = plt.subplots(4, 2, figsize=(16, 24))\naxes = axes.flatten()\n\n# Set colormap for cross-tabulation heatmaps\nheatmap_cmap = sns.color_palette(\"Blues\", as_cmap=True)\n\nfor idx, feature in enumerate(ordinal_features):\n    ax = axes[idx]\n    \n    # Calculate contingency counts\n    ct = pd.crosstab(df[feature], df[target])\n    \n    # Plot annotated heatmaps\n    sns.heatmap(ct, annot=True, fmt='d', cmap=heatmap_cmap, ax=ax, cbar=True)\n    \n    readable_name = feature_mapping.get(feature, feature.replace('_', ' ').title())\n    ax.set_title(f'{readable_name} vs {feature_mapping[target]}', fontsize=12, fontweight='bold')\n    ax.set_xlabel(feature_mapping[target])\n    ax.set_ylabel(readable_name)\n\nfor i in range(len(ordinal_features), len(axes)):\n    fig.delaxes(axes[i])\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:16.366542Z","iopub.execute_input":"2026-06-14T18:37:16.36689Z","iopub.status.idle":"2026-06-14T18:37:19.401685Z","shell.execute_reply.started":"2026-06-14T18:37:16.366852Z","shell.execute_reply":"2026-06-14T18:37:19.400674Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x2400 with 14 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":78},{"cell_type":"markdown","source":"## 9. Exploratory Data Analysis Observations: Categorical & Ordinal Features vs. Price Range\n\n### Overview of Insights\n\nThis section analyzes the contingency tables of binary, categorical, and ordinal features against the target variable Price Range:\n\n| Tier | Label |\n|------|-------|\n| 0 | Low Cost |\n| 1 | Medium Cost |\n| 2 | High Cost |\n| 3 | Very High Cost |\n\nBecause data points are relatively uniformly distributed across price tiers (~250 devices per tier), we look for **significant imbalances or distinct spikes in cell counts** to determine predictive power.\n\n---\n\n### 1. Noticeable Trends & Stronger Differentiators\n\nWhile categorical variables in this dataset are heavily uniform, a few features exhibit slight structural variations in the highest price tier (Tier 3).\n\n#### Bluetooth vs. Price Range\n\n- **The Data:** For price ranges 0, 1, and 2, the presence (1) or absence (0) of Bluetooth is completely balanced. However, in Tier 3 (Very High Cost), the count for devices *with* Bluetooth surges to **259**, while devices *without* Bluetooth drop to **241**.\n- **Takeaway:** While not a strict rule, premium tier devices are marginally more likely to feature Bluetooth.\n\n#### 4G Support vs. Price Range\n\n- **The Data:** A similar pattern emerges here. Tiers 0, 1, and 2 maintain an approximately equal distribution. In Tier 3, however, the number of devices featuring 4G spikes to **275** (the highest cell density in that matrix), while non-4G devices drop to **225**.\n- **Takeaway:** High-end devices show a stronger statistical baseline requirement for 4G connectivity.\n\n#### Wi-Fi vs. Price Range\n\n- **The Data:** Following the same trend, Tier 3 shows a noticeable concentration of Wi-Fi-enabled devices (**262**) compared to those without (**238**).\n- **Takeaway:** Wireless connectivity features see their highest concentration when moving into the premium price bracket.\n\n---\n\n### 2. Flat / Non-Predictive Features\n\nThese features show an almost perfectly uniform distribution across all price ranges, suggesting very low predictive importance for classification.\n\n#### 3G Support vs. Price Range\n\n- **The Data:** Across all price tiers (0 to 3), the counts remain completely static — roughly **115–127** devices lack 3G, while an overwhelming **373–387** devices possess 3G.\n- **Takeaway:** 3G support is ubiquitous. Because ~75% of phones have 3G regardless of whether they are budget or premium, this feature does not help differentiate price.\n\n#### Dual SIM & Touch Screen Support\n\n- **The Data:** Cell counts fluctuate randomly around the **240–260** baseline mark across all 4 price brackets. No linear pattern or distinct tier-based clustering exists.\n- **Takeaway:** Whether a phone supports dual SIMs or features a touch screen has virtually zero statistical influence on its final price class in this dataset.\n\n#### Number of Processor Cores vs. Price Range\n\n- **The Data:** This 8-row matrix shows an incredibly scattered distribution. For instance, single-core processors appear **76** times in Tier 1 but only **65** times in Tier 3. Octa-core processors appear roughly equally (~60–70 times) across all budget and premium ranges.\n- **Takeaway:** The absolute number of cores is distributed uniformly across the entire spectrum — a high-tier phone is just as likely to have 4 cores as a low-tier phone.\n\n---\n\n### Summary Table for Feature Selection\n\n| Feature Name | Visual Behavior | Modeling Impact | Action |\n|---|---|---|---|\n| 4G Support | Concentration spike in Tier 3 | Low / Moderate | ✅ Keep |\n| Wi-Fi | Concentration spike in Tier 3 | Low / Moderate | ✅ Keep |\n| Bluetooth | Slight shift in Tier 3 | Low | ⚠️ Keep / Optional |\n| Number of Cores | Uniformly scattered noise | Negligible | ❌ Drop Candidate |\n| Dual SIM | Uniform baseline distribution | Negligible | ❌ Drop Candidate |\n| Touch Screen | Uniform baseline distribution | Negligible | ❌ Drop Candidate |\n| 3G Support | Uniformly high across all tiers | Negligible | ❌ Drop Candidate |","metadata":{}},{"cell_type":"markdown","source":"## 10. Class Balance Analysis\nWe inspect the distribution of the target class labels (`price_range`) to confirm if the classification task is balanced.","metadata":{}},{"cell_type":"code","source":"# Plot countplot of target variable price_range\nplt.figure(figsize=(6, 5))\nax = sns.countplot(x='price_range', data=df, palette='rocket')\nplt.title('Distribution of Price Range (Target)', fontsize=14, fontweight='bold')\nplt.xlabel('Price Range')\nplt.ylabel('Count')\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:19.40308Z","iopub.execute_input":"2026-06-14T18:37:19.403466Z","iopub.status.idle":"2026-06-14T18:37:19.560557Z","shell.execute_reply.started":"2026-06-14T18:37:19.403425Z","shell.execute_reply":"2026-06-14T18:37:19.559703Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 600x500 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":79},{"cell_type":"code","source":"# Print numerical distribution count of target labels\ndf['price_range'].value_counts()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-14T18:37:19.561655Z","iopub.execute_input":"2026-06-14T18:37:19.561991Z","iopub.status.idle":"2026-06-14T18:37:19.57053Z","shell.execute_reply.started":"2026-06-14T18:37:19.561954Z","shell.execute_reply":"2026-06-14T18:37:19.56984Z"}},"outputs":[{"execution_count":80,"output_type":"execute_result","data":{"text/plain":"price_